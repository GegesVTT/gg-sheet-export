<div class="ggse-ui">
  <div class="ggse-frame">
    <span class="ggse-corner tl"><i></i></span><span class="ggse-corner tr"><i></i></span>
    <span class="ggse-corner bl"><i></i></span><span class="ggse-corner br"><i></i></span>

    <div class="ggse-head">
      <div class="ggse-kicker">Crónicas Bárdicas</div>
      <div class="ggse-title">{{localize "GGSE.Cards.ThemePickerTitle"}}</div>
      <div class="ggse-sub">{{localize "GGSE.Cards.ThemePickerSub"}}</div>
    </div>

    <div class="ggse-divider"><span class="ggse-gem"></span></div>

    <div class="ggse-picker">
      <div class="ggse-grid">
        {{{tilesHtml}}}
      </div>

      <div class="ggse-foot">
        <button type="button" class="ggse-cap" data-action="ggseThemeCancel">{{localize "GGSE.Cards.Cancel"}}</button>
        <button type="button" class="ggse-cap primary" data-action="ggseThemeApply">{{localize "GGSE.Cards.ApplyTheme"}}</button>
      </div>
    </div>
  </div>
</div>
